import { NextResponse } from "next/server";
import { headers } from "next/headers";
import Stripe from "stripe";
import { createClient } from "@supabase/supabase-js";

// Initialize Stripe with your Secret Key
const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, {
  apiVersion: "2023-10-16" as any, // Standard stable version
});

// Initialize Supabase with the Service Role Key to bypass RLS policies during webhook ingestion
const supabaseAdmin = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!
);

export async function POST(req: Request) {
  const body = await req.text();
  const signature = headers().get("Stripe-Signature");

  let event: Stripe.Event;

  try {
    if (!signature || !process.env.STRIPE_WEBHOOK_SECRET) {
      return NextResponse.json({ error: "Missing verification configurations." }, { status: 400 });
    }
    // Secure validation preventing spoofed requests
    event = stripe.webhooks.constructEvent(body, signature, process.env.STRIPE_WEBHOOK_SECRET);
  } catch (err: any) {
    console.error(`❌ Webhook signature validation failed: ${err.message}`);
    return NextResponse.json({ error: `Webhook Error: ${err.message}` }, { status: 400 });
  }

  const session = event.data.object as any;

  switch (event.type) {
    
    // 📍 EVENT 1: SUBSCRIPTION INITIATION OR SINGLE UPGRADES
    case "checkout.session.completed": {
      const userEmail = session.customer_details?.email;
      const subscriptionId = session.subscription;

      // Look up the corresponding parent profile by email address
      const { data: parent, error: findError } = await supabaseAdmin
        .from("parent_profiles")
        .select("id, sparks_balance")
        .eq("email", userEmail)
        .single();

      if (findError || !parent) {
        console.error(`Parent profile matching email ${userEmail} not found.`);
        return NextResponse.json({ error: "User profile target unresolved." }, { status: 404 });
      }

      // Fetch checkout details from Stripe to see exactly what product they purchased
      const lineItems = await stripe.checkout.sessions.listLineItems(session.id);
      const productName = lineItems.data[0]?.description || "";

      let targetTier = "Free Trial";
      let balanceAdjustment = 0;

      // Map Stripe Product description names directly to your UI states
      if (productName.includes("Unlimited") || productName.toLowerCase().includes("family")) {
        targetTier = "Family Unlimited";
      } else if (productName.includes("Solo") || productName.toLowerCase().includes("scholar")) {
        targetTier = "Solo Scholar";
        // Seed initial monthly credits upon successful signup
        balanceAdjustment = 10; 
      }

      // Update their account status securely
      const { error: updateError } = await supabaseAdmin
        .from("parent_profiles")
        .update({
          subscription_tier: targetTier,
          stripe_subscription_id: subscriptionId,
          // Cap the initialization step if they are rolling over from previous trials
          sparks_balance: Math.min((parent.sparks_balance || 0) + balanceAdjustment, 30)
        })
        .eq("id", parent.id);

      if (updateError) console.error("Error updating profile on checkout:", updateError);
      break;
    }

    // 📍 EVENT 2: MONTHLY RENEWALS & PROGRESSIVE ROLLOVER LOGIC
    case "invoice.payment_succeeded": {
      // Ignore initial setup invoices where a checkout session is already handling creation
      if (session.billing_reason === "subscription_create") {
        break;
      }

      const subscriptionId = session.subscription;
      
      // Pull down details from Stripe to see what tier this recurring subscription belongs to
      const stripeSub = await stripe.subscriptions.retrieve(subscriptionId);
      const priceId = stripeSub.items.data[0]?.price.id;

      // Look up the user by their saved Stripe subscription ID reference
      const { data: parent, error: lookupError } = await supabaseAdmin
        .from("parent_profiles")
        .select("id, sparks_balance, subscription_tier")
        .eq("stripe_subscription_id", subscriptionId)
        .single();

      if (lookupError || !parent) {
        console.error(`Could not locate parent profile assigned to subscription ID: ${subscriptionId}`);
        break;
      }

      // Execute programmatic credit increases exclusively for Solo Scholar tiers
      if (parent.subscription_tier === "Solo Scholar") {
        const currentBalance = parent.sparks_balance || 0;
        
        // Add 10 monthly Sparks, enforcing your 3-month aggregate hard ceiling of 30
        const rolledOverBalance = Math.min(currentBalance + 10, 30);

        await supabaseAdmin
          .from("parent_profiles")
          .update({ sparks_balance: rolledOverBalance })
          .eq("id", parent.id);
          
        console.log(`Successfully completed monthly replenishment. User ${parent.id} updated to ${rolledOverBalance} Sparks.`);
      }
      break;
    }

    // 📍 EVENT 3: CANCELLATIONS OR PAYMENT LAPSE SUSPENSIONS
    case "customer.subscription.deleted": {
      const subscriptionId = session.id;

      const { error: cancelError } = await supabaseAdmin
        .from("parent_profiles")
        .update({
          subscription_tier: "Free Trial",
          stripe_subscription_id: null,
          sparks_balance: 0 // Revoke premium balance access upon contract destruction
        })
        .eq("stripe_subscription_id", subscriptionId);

      if (cancelError) console.error("Error processing user down-tier cancellation route:", cancelError);
      break;
    }

    default:
      console.log(`Unhandled Stripe edge event variant received: ${event.type}`);
  }

  return NextResponse.json({ received: true }, { status: 200 });
}